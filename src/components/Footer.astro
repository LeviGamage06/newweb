---
const base = import.meta.env.BASE_URL;
const year = new Date().getFullYear();
---
<footer class="border-t border-stone/12 bg-ink-soft">
  <div class="mx-auto max-w-7xl px-6 pt-16 pb-10">
    <div class="grid gap-10 md:grid-cols-[2fr_1fr_1fr_1.8fr]">

      <!-- Brand -->
      <div>
        <a href={base} class="group flex items-center gap-px text-lg font-light tracking-[-0.01em] text-paper w-fit">
          <span class="group-hover:text-paper/70 transition-colors">Quid</span><span class="font-extrabold group-hover:text-proof transition-colors">E</span><span class="group-hover:text-paper/70 transition-colors">dge</span><span class="ml-px text-proof font-light">.</span>
        </a>
        <p class="mt-4 text-sm text-stone max-w-xs leading-relaxed">
          World-class video editing and content strategy for 7–8 figure entrepreneurs. Engineered for viral impact.
        </p>
        <p class="mt-5 flex items-center gap-2 text-xs text-stone/70">
          <span class="live-dot"></span>
          Accepting new clients
        </p>
      </div>

      <!-- Site links -->
      <div>
        <p class="label mb-5">Company</p>
        <ul class="space-y-3">
          {[["about","About"],["services","Services"],["work","Work"],["blog","Blog"]].map(([h,l]) => (
            <li><a href={`${base}${h}`} class="text-sm text-stone hover:text-paper transition-colors">{l}</a></li>
          ))}
        </ul>
      </div>

      <!-- Work links -->
      <div>
        <p class="label mb-5">Work with us</p>
        <ul class="space-y-3">
          {[["contact","Book a call"],["contact","Viral Sprint"],["contact","Digital Empire"]].map(([h,l]) => (
            <li><a href={`${base}${h}`} class="text-sm text-stone hover:text-paper transition-colors">{l}</a></li>
          ))}
        </ul>
      </div>

      <!-- Newsletter -->
      <div>
        <p class="label mb-5">Stay in the loop</p>
        <p class="text-sm text-stone mb-5 leading-relaxed">One email a month — branding insights, no spam.</p>
        <!-- TODO: replace YOUR_NEWSLETTER_FORM_ID -->
        <form action="https://formspree.io/f/YOUR_NEWSLETTER_FORM_ID" method="POST" class="flex gap-2">
          <label for="ft-email" class="sr-only">Email address</label>
          <input id="ft-email" name="email" type="email" required
            placeholder="you@example.com"
            class="min-w-0 flex-1 border border-stone/22 bg-transparent px-3 py-2.5 text-xs text-paper placeholder:text-stone/45 focus:border-proof focus:outline-none transition-colors"/>
          <input type="hidden" name="_subject" value="QuidEdge newsletter signup"/>
          <button type="submit" class="btn-primary !py-2.5 !px-4 shrink-0 text-[0.6rem]">Join</button>
        </form>
      </div>
    </div>

    <div class="mt-14 flex flex-col gap-2 border-t border-stone/10 pt-7 sm:flex-row sm:items-center sm:justify-between">
      <p class="text-xs text-stone/50">&copy; {year} QuidEdge (Levi &amp; Chami). All rights reserved.</p>
      <p class="text-xs text-stone/50">Engineered for Viral Impact.</p>
    </div>
  </div>
</footer>
